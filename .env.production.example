# Скопируйте в .env на сервере: cp .env.production.example .env
# Заполните значения, выполните php artisan key:generate
# Этот файл можно коммитить; реальный .env — нет.

APP_NAME="Фалькин Роман — портфолио"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ваш-домен.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

# Цены USD на лендинге (блок pricing)
PRICING_WEB_USD_FROM=1900
PRICING_MOBILE_USD_FROM=3900

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- База: на проде обычно MySQL ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio2026
DB_USERNAME=portfolio2026
DB_PASSWORD=сгенерируйте_надёжный_пароль

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Redis — если переключите cache/session/queue
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ваш-домен.ru"
MAIL_FROM_NAME="${APP_NAME}"

# Админка: только этот email пускает /admin
ADMIN_EMAIL=falkin95@mail.ru

# Пароль для первого сида на сервере (после db:seed можно удалить строку)
ADMIN_PASSWORD=

# Соцссылки и JSON-LD (полные URL)
# SEO_SAME_AS_THREADS=
# SEO_SAME_AS_INSTAGRAM=
# SEO_SAME_AS_TELEGRAM_URL=
# SOCIAL_THREADS_URL=
# SOCIAL_INSTAGRAM_URL=
# SOCIAL_TELEGRAM_URL=

# Уведомления о заявках в Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Юр. блок (опционально)
# LEGAL_INN=
# LEGAL_ADDRESS=

VITE_APP_NAME="${APP_NAME}"
